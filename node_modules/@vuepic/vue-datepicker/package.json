{
  "name": "@vuepic/vue-datepicker",
  "version": "14.0.0",
  "description": "Datepicker component for Vue 3",
  "author": "Vuepic",
  "private": false,
  "license": "MIT",
  "homepage": "https://vue3datepicker.com",
  "type": "module",
  "module": "dist/vue-datepicker.js",
  "types": "dist/index.d.ts",
  "style": "dist/main.css",
  "files": [
    "dist/*",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vue-datepicker.js",
      "default": "./dist/vue-datepicker.js"
    },
    "./dist/main.css": {
      "import": "./dist/main.css",
      "require": "./dist/main.css",
      "default": "./dist/main.css"
    }
  },
  "dependencies": {
    "@date-fns/tz": "^1.5.0",
    "@floating-ui/vue": "^1.1.11",
    "@vueuse/core": "^14.3.0",
    "date-fns": "^4.4.0"
  },
  "devDependencies": {
    "vue": "^3.5.35"
  },
  "peerDependencies": {
    "vue": ">=3.5.0"
  },
  "engines": {
    "node": ">=18.12.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vuepic/vue-datepicker.git"
  },
  "bugs": {
    "url": "https://github.com/Vuepic/vue-datepicker/issues"
  },
  "keywords": [
    "date",
    "datepicker",
    "daterangepicker",
    "datetimepicker",
    "vue",
    "vue-datepicker",
    "vue3-datepicker"
  ],
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "scripts": {
    "clean": "rimraf ./dist",
    "build": "run-s clean type-check lint fmt:check build:lib",
    "type-check": "vue-tsc --build",
    "build:lib": "vite build --mode production",
    "test": "cross-env NODE_ENV=test vitest",
    "test:coverage": "cross-env NODE_ENV=test vitest --environment jsdom run --coverage",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint src --fix",
    "lint:eslint": "eslint \"src/**\" --fix --cache",
    "format": "oxfmt .",
    "fmt:check": "oxfmt --check"
  }
}