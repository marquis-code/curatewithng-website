{
  "name": "@nuxtjs/robots",
  "type": "module",
  "version": "6.1.1",
  "description": "Tame the robots crawling and indexing your Nuxt site with ease.",
  "author": {
    "name": "Harlan Wilton",
    "email": "harlan@harlanzw.com",
    "url": "https://harlanzw.com/"
  },
  "contributors": [
    "Ricardo Gobbo de Souza <ricardogobbosouza@yahoo.com.br>",
    "Harlan Wilton <harlan@harlanzw.com>"
  ],
  "license": "MIT",
  "funding": "https://github.com/sponsors/harlan-zw",
  "homepage": "https://nuxtseo.com/robots",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nuxt-modules/robots.git"
  },
  "bugs": {
    "url": "https://github.com/nuxt-modules/robots/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    },
    "./util": "./dist/util.mjs",
    "./content": "./dist/content.mjs"
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      "content": [
        "dist/content"
      ],
      "util": [
        "dist/util"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "zod": ">=3"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "dependencies": {
    "@fingerprintjs/botd": "^2.0.0",
    "@nuxt/kit": "^4.4.8",
    "consola": "^3.4.2",
    "defu": "^6.1.7",
    "h3": "^1.15.11",
    "nuxt-site-config": "^4.0.8",
    "nuxtseo-shared": "^5.3.0",
    "pathe": "^2.0.3",
    "pkg-types": "^2.3.1",
    "ufo": "^1.6.4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@arethetypeswrong/cli": "^0.18.3",
    "@headlessui/vue": "^1.7.23",
    "@iconify-json/logos": "^1.2.11",
    "@iconify-json/ri": "^1.2.10",
    "@iconify-json/tabler": "^1.2.35",
    "@nuxt/content": "^3.14.0",
    "@nuxt/devtools-kit": "4.0.0-alpha.7",
    "@nuxt/devtools-ui-kit": "4.0.0-alpha.7",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/test-utils": "^4.0.3",
    "@nuxtjs/color-mode": "^4.0.1",
    "@nuxtjs/i18n": "^10.4.0",
    "@unocss/nuxt": "^66.7.0",
    "@unocss/preset-icons": "^66.7.0",
    "@unocss/preset-uno": "^66.7.0",
    "@unocss/runtime": "^66.7.0",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "better-sqlite3": "^12.10.0",
    "bumpp": "^11.1.0",
    "eslint": "^10.4.1",
    "eslint-plugin-harlanzw": "^0.17.0",
    "execa": "^9.6.1",
    "firebase-functions": "^7.2.5",
    "happy-dom": "^20.10.2",
    "nuxt": "^4.4.8",
    "nuxtseo-layer-devtools": "^5.3.0",
    "playwright-core": "^1.60.0",
    "radix3": "^1.1.2",
    "sirv": "^3.0.2",
    "std-env": "^4.1.0",
    "typescript": "^6.0.3",
    "unbuild": "^3.6.1",
    "unocss": "^66.7.0",
    "vitest": "^4.1.8",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0"
  },
  "scripts": {
    "lint": "eslint . --fix",
    "client:build": "node -e \"require('fs').cpSync('devtools','dist/devtools',{recursive:true})\"",
    "build": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt-module-build build && npm run client:build",
    "dev": "nuxt dev playground",
    "prepare:fixtures": "nuxt prepare playground && nuxt prepare test/fixtures/basic && nuxt prepare test/fixtures/i18n && nuxt prepare test/fixtures/content-v3",
    "dev:build": "nuxt build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt-module-build build && nuxt prepare playground && pnpm run client:build",
    "release": "pnpm build && bumpp -x \"npx changelogen --output=CHANGELOG.md\"",
    "test": "pnpm run prepare:fixtures && vitest",
    "typecheck": "nuxt typecheck",
    "test:attw": "attw --pack"
  }
}